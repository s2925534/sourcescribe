# Copy this file to .env and adjust values for your machine.

# Default input folder. Completed jobs are written under:
# source/completed/<original file name without extension>/
TRANSCRIBER_SOURCE_DIR=source

# Default backend. Keep false for local Whisper. Set true to use OpenAI by default.
TRANSCRIBER_USE_AI=false

# Language hint for better transcription quality. Leave blank for auto-detection.
TRANSCRIBER_LANGUAGE=en

# Helpful context for names, acronyms, punctuation, and meeting vocabulary.
TRANSCRIBER_PROMPT=This is a meeting recording. Preserve names, acronyms, decisions, and action items.

# Local Whisper settings used when TRANSCRIBER_USE_AI=false.
TRANSCRIBER_LOCAL_MODEL=turbo
TRANSCRIBER_LOCAL_DEVICE=
TRANSCRIBER_WHISPER_BIN=

# OpenAI settings used when TRANSCRIBER_USE_AI=true or --ai is passed.
OPENAI_API_KEY=
TRANSCRIBER_OPENAI_MODEL=gpt-4o-transcribe
TRANSCRIBER_DIARIZE=false
TRANSCRIBER_SPEAKER_LABELS=
TRANSCRIBER_KNOWN_SPEAKERS=

# OpenAI upload/chunking settings for long recordings.
TRANSCRIBER_CHUNK_MINUTES=20
TRANSCRIBER_MAX_UPLOAD_MB=24

# AI help creates cleaned transcript, summary, and action-item artifacts.
TRANSCRIBER_AI_HELP=false
TRANSCRIBER_AI_HELP_MODEL=auto
TRANSCRIBER_AI_HELP_CHUNK_CHARS=12000
